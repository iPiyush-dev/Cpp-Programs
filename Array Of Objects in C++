#include <iostream>
using namespace std;

// It takes the input of n student's name and their marks and then print them in suitable format.

class Student
{

public:
    string name;
    int marks;

    void inputNames()
    {
        cin >> name;
    }

    void inputMarks()
    {
        cin >> marks;
    }

    void display()
    {
        cout << "The name of the Student is: " << name << " and the mark is: " << marks << endl;
    }
};

int main()
{
    
    int n;

    cout << "Enter the numbers of student in your class?" << endl;
    cin >> n;

    Student s[n];

    for (int i = 0; i < n; i++)
    {
        cout << "Enter name: ";
        s[i].inputNames();
        cout << "Enter marks: ";
        s[i].inputMarks();
    }

    for (int i = 0; i < n; i++)
    {
        s[i].display();
    }

    return 0;
}
