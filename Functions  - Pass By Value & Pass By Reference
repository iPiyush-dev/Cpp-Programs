int main(){

    int x = 5, y = 7;
    cout<<"\n\n\t\t Pass By Reference \n";
    void func(int&, int&);
    func(x,y);
    cout<<"The output from calling program is: ";
    cout<<"\n x = "<<x;
    cout<<"\n y = "<<y;

    return 0;
}

void func(int& s, int& u){
    s*=10;
    u*=5;
}
